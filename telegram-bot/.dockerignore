# Note: build context is the repo root (so ../gateway is visible
# through tool.uv.sources). Most entries in this file are duplicated
# in gateway/.dockerignore; that's intentional because we ignore
# against the root context during the bot build.
.venv/
__pycache__/
*.pyc
*.pyo
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.hypothesis/
.coverage
htmlcov/
dist/
build/
tests/
docs/
*.md
# Keep both README.md files; hatchling requires them to build the
# wheels. The gateway's README.md (consumed through tool.uv.sources'
# path dep) and the telegram-bot's own README.md both need to make
# it into the Docker build context.
!README.md
!gateway/README.md
.git/
.gitignore

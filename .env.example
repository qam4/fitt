# FITT hub - docker compose environment.
#
# Copy to .env (alongside docker-compose.yml) and fill in. The .env
# file is gitignored; real values stay local.

# ---------------------------------------------------------------
# Paths and ownership
# ---------------------------------------------------------------

# Host directory that holds FITT's config.yaml, secrets.yaml,
# identity/, sessions/, logs/, and open-webui/.
#
# QNAP (match where Jellyfin, Plex etc. live on your NAS):
#   FITT_HOME=/share/Public/fitt
# Linux server:
#   FITT_HOME=/srv/fitt
# macOS / Windows + Docker Desktop:
#   FITT_HOME=/Users/you/.fitt
#
FITT_HOME=/share/Public/fitt

# User/group that owns $FITT_HOME on the host. The containers run
# as this uid/gid so they can read/write without ACL tricks. QNAP
# admins default to 1000:1000.
PUID=1000
PGID=1000

# Operator timezone (IANA name, e.g. America/New_York,
# Europe/Paris). Drives LOCAL-TIME DISPLAY on the dashboard and
# the "[Current time]" line the model sees. Logs are always UTC,
# and cron schedules default to UTC unless a per-cron --timezone
# is given. Set it to YOUR zone — the value below is only a
# placeholder.
TZ=America/New_York


# ---------------------------------------------------------------
# Ports
# ---------------------------------------------------------------

# The gateway's internal listen port. Default 8421 was chosen to
# dodge common collisions (8080 is QNAP's admin UI, 8000/8888 are
# common dev-server defaults). If you run `network_mode: host` on
# a machine where 8421 is already taken, change both FITT_PORT
# and GATEWAY_HOST_PORT together.
FITT_PORT=8421

# Host-side port compose publishes the gateway on. With the default
# bridge networking this can differ from FITT_PORT to sidestep a
# host-level conflict without moving the internal port.
#   QNAP example: host port 8181 -> container port 8421 via
#     FITT_PORT=8421 and GATEWAY_HOST_PORT=8181
GATEWAY_HOST_PORT=8421

# Bearer token Open WebUI presents to the gateway. This is the
# same token clients send as `Authorization: Bearer <token>`; it
# already lives in your secrets.yaml under allowed_tokens[].token.
# Copy it here so compose can inject it into the Open WebUI
# container as OPENAI_API_KEY.
FITT_BEARER_TOKEN=REPLACE_WITH_TOKEN_FROM_SECRETS_YAML

# ---------------------------------------------------------------
# Open WebUI
# ---------------------------------------------------------------

# Open WebUI signup gate. The compose file runs Open WebUI with
# ENABLE_PERSISTENT_CONFIG=false, so this value is authoritative on
# every boot (the Admin UI toggle no longer sticks across a
# restart). Default is closed.
#
# Fresh-install bootstrap (one time): set this to true, run
# `docker compose up -d open-webui`, open the UI and create your
# first account (it becomes admin), then set it back to false and
# `docker compose up -d open-webui` again to close the door. See
# quickstart step 16.
WEBUI_ENABLE_SIGNUP=false

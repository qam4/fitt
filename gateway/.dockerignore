# Keep the build context small and the image deterministic. Only
# pyproject.toml, uv.lock, and src/ actually matter for the build.
.venv/
__pycache__/
*.pyc
*.pyo
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.hypothesis/
.coverage
htmlcov/
dist/
build/
tests/
docs/
*.md
# Keep the package's README.md - hatchling reads it per
# pyproject.toml's `readme = "README.md"` and refuses to build
# the wheel if it's missing. Found the hard way during a NAS
# docker build.
!README.md
.git/
.gitignore
.dockerignore
Dockerfile
